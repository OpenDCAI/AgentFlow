{
  "model_name": "openai/gpt-oss-120b",
  "api_key": "${OPENROUTER_API_KEY}",
  "base_url": "https://openrouter.ai/api/v1",

  "max_depth": 20,
  "branching_factor": 2,
  "depth_threshold": 2,

  "min_depth": 3,
  "max_selected_traj": 3,
  "path_similarity_threshold": 0.7,

  "number_of_seed": null,

  "resource_types": [],
  "resource_init_configs": {},

  "sandbox_server_url": "http://127.0.0.1:18890",
  "sandbox_auto_start": true,
  "sandbox_config_path": "configs/server/doc_ds_sandbox.json",
  "sandbox_timeout": 300,

  "available_tools": [
    "doc-search",
    "doc-read",
    "ds_inspect_data",
    "ds_read_csv",
    "ds_run_python"
  ],

  "seed_description": "Document or data directory",

  "seeds_file": "seeds/web/seeds.jsonl",
  "output_dir": "results/doc_ds",

  "description_path": "configs/synthesis/instructions/doc_ds_instruction.md",
  "skills_root": "synthesis/skills",
  "skill": {
    "enabled": false
  }
}