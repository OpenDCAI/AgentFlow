{

  "model_name": "openai/gpt-oss-120b",
  "api_key": "${OPENROUTER_API_KEY}",
  "base_url": "https://openrouter.ai/api/v1",

  "max_depth": 10,
  "branching_factor": 1,
  "depth_threshold": 1,

  "min_depth": 3,
  "max_selected_traj": 1,
  "path_similarity_threshold": 0.7,

  "number_of_seed": null,

  "resource_types": ["vm"],
  "resource_init_configs": {
    "vm": {
      "content": {}
    }
  },

  "sandbox_server_url": "http://127.0.0.1:18890",
  "sandbox_auto_start": false,
  "sandbox_config_path": "configs/sandbox-server/vm_config.json",
  "sandbox_timeout": 120,

  "available_tools": ["vm-screenshot", "vm-click", "vm-double_click", "vm-type", "vm-key", "vm-key_down", "vm-key_up", "vm-hotkey", "vm-scroll", "vm-drag", "vm-move", "vm-mouse_down", "vm-mouse_up", "vm-right_click"],

  "seed_description": "Starting entity and its description",

  "seeds_file": "seeds/vm/seeds.jsonl",
  "output_dir": "results",
  
  "description_path": "configs/synthesis/instructions/GUI_instruction.md",
  "skills_root": "synthesis/skills",
  "skill": {
    "enabled": false
  }
}

