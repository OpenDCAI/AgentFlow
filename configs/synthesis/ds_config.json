{
  "model_name": "openai/gpt-oss-120b",
  "api_key": "${OPENAI_API_KEY}",
  "base_url": "${OPENAI_API_URL}",

  "max_depth": 20,
  "branching_factor": 2,
  "depth_threshold": 2,
  "min_depth": 3,
  "max_selected_traj": 1,
  "path_similarity_threshold": 0.7,

  "sandbox_server_url": "http://127.0.0.1:18890",
  "available_tools": ["ds_inspect_data", "ds_read_csv", "ds_run_python"],

  "seed_description": "Data directory containing CSV files",
  "seeds_file": "seeds/ds/seeds.jsonl",
  "output_dir": "results",
  
  "description_path": "configs/synthesis/instructions/ds_instruction.md",
  "skills_root": "synthesis/skills",
  "skill": {
    "enabled": false
  }
}